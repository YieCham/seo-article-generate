{
  "name": "ai-article-agent",
  "version": "0.1.0",
  "description": "Electron app for AI article creation with Cursor Agent skills",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:quiet": "wscript //B //nologo scripts/start-dev-hidden.vbs",
    "shortcut:desktop": "node scripts/create-desktop-shortcut.mjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "open:win": "powershell -NoProfile -Command \"if (Test-Path 'dist/win-unpacked/AIWriting Assistant.exe') { Start-Process 'dist/win-unpacked/AIWriting Assistant.exe' } else { Write-Host '请先运行 npm run dist:win 完成打包'; exit 1 }\""
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^36.3.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.ai-article-agent.app",
    "productName": "AIWriting Assistant",
    "copyright": "Copyright © 2026",
    "icon": "icons/icon.png",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "icons/icon.png",
        "to": "icon.png"
      }
    ],
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "icons/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AIWriting Assistant",
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "2052"
    }
  }
}
